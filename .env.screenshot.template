# Screenshot Pipeline Environment Configuration
# Copy this file to .env.screenshot at the repo root and customize

# IronClaw binary path (default: ../../target/release/ironclaw)
# IRONCLAW_BIN=/path/to/ironclaw

# Screenshot server configuration
SCREENSHOT_PORT=13001
SCREENSHOT_HOST=127.0.0.1
IRONCLAW_URL=http://127.0.0.1:13001

# Authentication token for API calls
# If ~/.ironclaw/.env contains GATEWAY_AUTH_TOKEN, that takes priority over this value
GATEWAY_AUTH_TOKEN=screenshot-test-token

# Viewport dimensions (WIDTHxHEIGHT)
SCREENSHOT_VIEWPORT=1280x800

# Health check timeout in seconds
HEALTH_TIMEOUT=60

# Example custom configuration for CI:
# SCREENSHOT_VIEWPORT=1920x1080
# SCREENSHOT_PORT=8080
# IRONCLAW_BIN=/opt/ironclaw/ironclaw
